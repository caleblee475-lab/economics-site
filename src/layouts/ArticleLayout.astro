---
const { frontmatter } = Astro.props;
const base = import.meta.env.BASE_URL;

const pubDate = new Date(frontmatter.pubDate);
const formattedDate = pubDate.toLocaleDateString('en-GB', {
  day: '2-digit',
  month: '2-digit',
  year: 'numeric'
});

// Helper to construct the correct path for the hero background
const heroImagePath = frontmatter.coverImage.startsWith('/') 
  ? `${base}${frontmatter.coverImage.slice(1)}` 
  : `${base}${frontmatter.coverImage}`;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{frontmatter.title}</title>
    <style>
      body { 
        font-family: 'Georgia', serif; 
        background-color: #F9F9F8; 
        color: #111; 
        margin: 0; 
        padding: 0; 
      }
      
      .paper-container {
        max-width: 768px; 
        margin: 0 auto; 
        background-color: #FFFFFF; 
        box-shadow: 0 0 20px rgba(0,0,0,0.05); 
        min-height: 100vh;
      }

      .nav-bar { 
        text-align: center; 
        padding: 2rem 0 1rem 0;
        font-family: 'Helvetica', 'Inter', sans-serif; 
        font-weight: bold; 
      }
      .nav-bar a { color: #111; text-decoration: none; margin: 0 10px; }
      .nav-bar a:hover { text-decoration: underline; }

      .hero-section {
        position: relative;
        height: 50vh; 
        display: flex;
        flex-direction: column;
        justify-content: flex-end; 
        padding: 2rem;
        background-size: cover;
        background-position: center;
        border-top: 2px solid #111;
        border-bottom: 2px solid #111;
      }
      
      .hero-overlay {
        position: absolute;
        top: 0; left: 0; right: 0; bottom: 0;
        background: linear-gradient(to bottom, rgba(0,0,0,0.1), rgba(0,0,0,0.85));
        z-index: 1;
      }

      .hero-text {
        position: relative;
        z-index: 2;
        color: #FFFFFF; 
      }
      
      .article-title {
        font-size: 2.5rem;
        font-weight: bold;
        margin-bottom: 0.5rem;
        line-height: 1.2;
        font-family: 'Helvetica', 'Inter', sans-serif;
      }
      
      .article-meta {
        font-size: 0.9rem;
        text-transform: uppercase;
        font-weight: 600;
        color: #E5E5E5;
        font-family: 'Helvetica', 'Inter', sans-serif;
      }

      .content {
        padding: 2rem; 
        line-height: 1.8; 
        font-size: 1.1rem;
      }
      
      .content img {
        border: 2px solid #111;
        border-radius: 4px;
        max-width: 100%;
      }
    </style>
  </head>
  <body>
    <div class="paper-container">
      <div class="nav-bar">
        <a href={base}>Home</a> | 
        <a href={`${base}apac`}>APAC</a> | 
        <a href={`${base}europe`}>Europe</a>
      </div>

      <div class="hero-section" style={`background-image: url('${heroImagePath}');`}>
        <div class="hero-overlay"></div>
        <div class="hero-text">
          <h1 class="article-title">{frontmatter.title}</h1>
          <div class="article-meta">Uploaded &bull; {formattedDate}</div>
        </div>
      </div>

      <div class="content">
        <slot />
      </div>
    </div>
  </body>
</html>